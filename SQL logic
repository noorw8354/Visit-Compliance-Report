        WHEN f.country_code_3d = 'JOR' THEN from_utc_timestamp(b.Call_Datetime_vod__c, 'Asia/Amman')
        WHEN f.country_code_3d = 'KEN' THEN from_utc_timestamp(b.Call_Datetime_vod__c, 'Africa/Nairobi')
        WHEN f.country_code_3d = 'SAU' THEN from_utc_timestamp(b.Call_Datetime_vod__c, 'Asia/Riyadh')
        WHEN f.country_code_3d = 'KWT' THEN from_utc_timestamp(b.Call_Datetime_vod__c, 'Asia/Kuwait')
        WHEN f.country_code_3d = 'LBN' THEN from_utc_timestamp(b.Call_Datetime_vod__c, 'Asia/Beirut')
        WHEN f.country_code_3d = 'MUS' THEN from_utc_timestamp(b.Call_Datetime_vod__c, 'Indian/Mauritius')
        WHEN f.country_code_3d = 'MAR' THEN from_utc_timestamp(b.Call_Datetime_vod__c, 'Africa/Casablanca')

        WHEN f.country_code_3d = 'DZA' THEN date_format(from_utc_timestamp(a.min_start_time, 'Africa/Algiers'), 'EEEE')
        WHEN f.country_code_3d = 'BHR' THEN date_format(from_utc_timestamp(a.min_start_time, 'Asia/Bahrain'), 'EEEE')

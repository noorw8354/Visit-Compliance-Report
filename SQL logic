      /* Country validity window (MIN(Start_Time_vod__c)) */
      CASE
        WHEN f.country_code_3d = 'DZA' AND date_format(from_utc_timestamp(a.min_start_time, 'Africa/Algiers'), 'HH:mm:ss') BETWEEN '08:00:00' AND '23:00:00' AND date_format(from_utc_timestamp(a.min_start_time, 'Africa/Algiers'), 'EEEE') NOT IN ('Friday') THEN 'Valid Call'

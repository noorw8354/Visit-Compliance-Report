        WHEN f.country_code_3d = 'EGY' AND date_format(from_utc_timestamp(a.min_start_time, 'Africa/Cairo'), 'HH:mm:ss') BETWEEN '08:00:00' AND '23:00:00' AND date_format(from_utc_timestamp(a.min_start_time, 'Africa/Cairo'), 'EEEE') NOT IN ('Friday') THEN 'Valid Call'
        WHEN f.country_code_3d = 'GAB' AND date_format(from_utc_timestamp(a.min_start_time, 'Africa/Libreville'), 'HH:mm:ss') BETWEEN '08:00:00' AND '23:00:00' AND date_format(from_utc_timestamp(a.min_start_time, 'Africa/Libreville'), 'EEEE') NOT IN ('Sunday') THEN 'Valid Call'
        WHEN f.country_code_3d = 'CIV' AND date_format(from_utc_timestamp(a.min_start_time, 'Africa/Abidjan'), 'HH:mm:ss') BETWEEN '08:00:00' AND '23:00:00' AND date_format(from_utc_timestamp(a.min_start_time, 'Africa/Abidjan'), 'EEEE') NOT IN ('Sunday') THEN 'Valid Call'
        WHEN f.country_code_3d = 'JOR' AND date_format(from_utc_timestamp(a.min_start_time, 'Asia/Amman'), 'HH:mm:ss') BETWEEN '08:00:00' AND '23:00:00' AND date_format(from_utc_timestamp(a.min_start_time, 'Asia/Amman'), 'EEEE') NOT IN ('Friday') THEN 'Valid Call'
        WHEN f.country_code_3d = 'KEN' AND date_format(from_utc_timestamp(a.min_start_time, 'Africa/Nairobi'), 'HH:mm:ss') BETWEEN '08:00:00' AND '23:00:00' AND date_format(from_utc_timestamp(a.min_start_time, 'Africa/Nairobi'), 'EEEE') NOT IN ('Sunday') THEN 'Valid Call'
        WHEN f.country_code_3d = 'SAU' AND date_format(from_utc_timestamp(a.min_start_time, 'Asia/Riyadh'), 'HH:mm:ss') BETWEEN '08:00:00' AND '23:00:00' AND date_format(from_utc_timestamp(a.min_start_time, 'Asia/Riyadh'), 'EEEE') NOT IN ('Friday','Saturday') THEN 'Valid Call'
        WHEN f.country_code_3d = 'KWT' AND date_format(from_utc_timestamp(a.min_start_time, 'Asia/Kuwait'), 'HH:mm:ss') BETWEEN '08:00:00' AND '23:00:00' AND date_format(from_utc_timestamp(a.min_start_time, 'Asia/Kuwait'), 'EEEE') NOT IN ('Friday','Saturday') THEN 'Valid Call'
        WHEN f.country_code_3d = 'LBN' AND date_format(from_utc_timestamp(a.min_start_time, 'Asia/Beirut'), 'HH:mm:ss') BETWEEN '08:00:00' AND '23:00:00' AND date_format(from_utc_timestamp(a.min_start_time, 'Asia/Beirut'), 'EEEE') NOT IN ('Sunday') THEN 'Valid Call'
        WHEN f.country_code_3d = 'MUS' AND date_format(from_utc_timestamp(a.min_start_time, 'Indian/Mauritius'), 'HH:mm:ss') BETWEEN '08:00:00' AND '23:00:00' AND date_format(from_utc_timestamp(a.min_start_time, 'Indian/Mauritius'), 'EEEE') NOT IN ('Sunday') THEN 'Valid Call'
        WHEN f.country_code_3d = 'MAR' AND date_format(from_utc_timestamp(a.min_start_time, 'Africa/Casablanca'), 'HH:mm:ss') BETWEEN '08:00:00' AND '23:00:00' AND date_format(from_utc_timestamp(a.min_start_time, 'Africa/Casablanca'), 'EEEE') NOT IN ('Sunday') THEN 'Valid Call'
        WHEN f.country_code_3d = 'NGA' AND date_format(from_utc_timestamp(a.min_start_time, 'Africa/Lagos'), 'HH:mm:ss') BETWEEN '08:00:00' AND '23:00:00' AND date_format(from_utc_timestamp(a.min_start_time, 'Africa/Lagos'), 'EEEE') NOT IN ('Sunday') THEN 'Valid Call'
        WHEN f.country_code_3d = 'OMN' AND date_format(from_utc_timestamp(a.min_start_time, 'Asia/Muscat'), 'HH:mm:ss') BETWEEN '08:00:00' AND '23:00:00' AND date_format(from_utc_timestamp(a.min_start_time, 'Asia/Muscat'), 'EEEE') NOT IN ('Friday','Saturday') THEN 'Valid Call'
        WHEN f.country_code_3d = 'PAK' AND date_format(from_utc_timestamp(a.min_start_time, 'Asia/Karachi'), 'HH:mm:ss') BETWEEN '07:00:00' AND '23:00:00' AND date_format(from_utc_timestamp(a.min_start_time, 'Asia/Karachi'), 'EEEE') NOT IN ('Sunday') THEN 'Valid Call'
        WHEN f.country_code_3d = 'QAT' AND date_format(from_utc_timestamp(a.min_start_time, 'Asia/Qatar'), 'HH:mm:ss') BETWEEN '08:00:00' AND '23:00:00' AND date_format(from_utc_timestamp(a.min_start_time, 'Asia/Qatar'), 'EEEE') NOT IN ('Friday','Saturday') THEN 'Valid Call'
        WHEN f.country_code_3d = 'ZAF' AND date_format(from_utc_timestamp(a.min_start_time, 'Africa/Johannesburg'), 'HH:mm:ss') BETWEEN '07:00:00' AND '17:00:00' AND date_format(from_utc_timestamp(a.min_start_time, 'Africa/Johannesburg'), 'EEEE') NOT IN ('Sunday') THEN 'Valid Call'
        WHEN f.country_code_3d = 'SEN' AND date_format(from_utc_timestamp(a.min_start_time, 'Africa/Dakar'), 'HH:mm:ss') BETWEEN '08:00:00' AND '23:00:00' AND date_format(from_utc_timestamp(a.min_start_time, 'Africa/Dakar'), 'EEEE') NOT IN ('Sunday') THEN 'Valid Call'
        WHEN f.country_code_3d = 'TGO' AND date_format(from_utc_timestamp(a.min_start_time, 'Africa/Lome'), 'HH:mm:ss') BETWEEN '08:00:00' AND '23:00:00' AND date_format(from_utc_timestamp(a.min_start_time, 'Africa/Lome'), 'EEEE') NOT IN ('Sunday') THEN 'Valid Call'
        WHEN f.country_code_3d = 'TUR' AND date_format(from_utc_timestamp(a.min_start_time, 'Europe/Istanbul'), 'HH:mm:ss') BETWEEN '08:00:00' AND '23:00:00' AND date_format(from_utc_timestamp(a.min_start_time, 'Europe/Istanbul'), 'EEEE') NOT IN ('Sunday') THEN 'Valid Call'
        WHEN f.country_code_3d = 'ARE' AND date_format(from_utc_timestamp(a.min_start_time, 'Asia/Dubai'), 'HH:mm:ss') BETWEEN '08:00:00' AND '23:00:00' AND date_format(from_utc_timestamp(a.min_start_time, 'Asia/Dubai'), 'EEEE') NOT IN ('Friday','Saturday') THEN 'Valid Call'
        ELSE 'Invalid Call'
      END AS call_validity,

      /* Karachi diff in minutes (MIN(Start_Time_vod__c) vs Call_Datetime) */
      ROUND(
        (
          unix_timestamp(CAST(from_utc_timestamp(a.min_start_time, 'Asia/Karachi') AS TIMESTAMP)) -
          unix_timestamp(CAST(from_utc_timestamp(b.Call_Datetime_vod__c, 'Asia/Karachi') AS TIMESTAMP))
        ) / 60.0
        , 1
      ) AS Time_Diff_days,

      /* Other fields */
      b.Status_vod__c AS status,
      b.OwnerId,
      b.Territory_vod__c AS territory_id,
      c.Name AS user_name,
      d.Name AS account_name,
      e.Name AS manager_name,
      f.Market AS Market,
      f.country_code_3d AS country_code_3d,
      b.Status_vod__c AS call_status,

      /* -------- next-call time difference (minutes) per user/country) --------
         Use LEAD over min_start_time; measure gap from current max_start_time to next min_start_time
      */
      (
        unix_timestamp(
          LEAD(CAST(a.min_start_time AS TIMESTAMP))
          OVER (PARTITION BY f.country_code_3d, c.Name ORDER BY a.min_start_time)
        )
        -
        unix_timestamp(CAST(a.max_start_time AS TIMESTAMP))
      ) / 60.0 AS call_diff_min

    FROM
      (
        SELECT *
        FROM prod_catlg_globaldl_sanitized.salesforce_expert.call
        WHERE ((Territory_vod__c LIKE '%21.%') OR (Territory_vod__c LIKE '%22.%'))
          AND Territory_vod__c IS NOT NULL
          AND isdeleted = 'False'
          AND Status_vod__c = 'Submitted_vod'
          --AND OwnerId = '005Ij000000Dxl8IAC'
          AND Call_Datetime_vod__c >= '2025-10-01 00:00:00.0000000'
      ) b

      /* Aggregate callkeymessage once per Call2_vod__c to get MIN/MAX */
      LEFT JOIN (
        SELECT
          Call2_vod__c,
          MIN(Start_Time_vod__c) AS min_start_time,
          MAX(Start_Time_vod__c) AS max_start_time
        FROM prod_catlg_globaldl_sanitized.salesforce_expert.callkeymessage
        GROUP BY Call2_vod__c
      ) a
        ON b.Id = a.Call2_vod__c

      LEFT JOIN prod_catlg_globaldl_sanitized.salesforce_expert.user c
        ON b.OwnerId = c.id

      LEFT JOIN prod_catlg_globaldl_sanitized.salesforce_expert.account d
        ON b.Account_vod__c = d.id

      LEFT JOIN prod_catlg_globaldl_sanitized.salesforce_expert.user e
        ON c.ManagerId = e.id
      LEFT JOIN (
        SELECT *
        FROM prod_catlg_globaldl_sanitized.salesforce_expert.address
        WHERE IsDeleted = 'False' AND Primary_vod__c = 'True'
      ) ad
        ON b.Account_vod__c = ad.Account_vod__c

      LEFT JOIN (
        SELECT DISTINCT *
        FROM epr_stage.country_mapping
      ) f
        ON RIGHT(b.MarketCode, 2) = f.Country_Code_2d
LEFT JOIN (select * from prod_catlg_globaldl_sanitized.expert_manual_files.rep_target) Trt 
        ON b.Territory_vod__c = Trt.Territory_Label 
        AND CONCAT('Q', QUARTER(b.Call_Datetime_vod__c), ' ', YEAR(b.Call_Datetime_vod__c)) = Trt.Target_Period
    
    WHERE
      b.Call_Datetime_vod__c >= '2025-10-01 00:00:00.0000000'
      AND f.Market in ('KSA','N Africa','RSA','SSA','Pakistan','GNE','Türkiye')
      --and b.Id = 'a04TL00000fxhitYAA'
  ) bc
) g

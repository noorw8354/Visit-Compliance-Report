        WHEN f.country_code_3d = 'COG' AND date_format(from_utc_timestamp(a.min_start_time, 'Africa/Brazzaville'), 'HH:mm:ss') BETWEEN '08:00:00' AND '23:00:00' AND date_format(from_utc_timestamp(a.min_start_time, 'Africa/Brazzaville'), 'EEEE') NOT IN ('Sunday') THEN 'Valid Call'

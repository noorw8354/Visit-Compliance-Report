        WHEN f.country_code_3d = 'GAB' THEN date_format(from_utc_timestamp(a.min_start_time, 'Africa/Libreville'), 'EEEE')
        WHEN f.country_code_3d = 'CIV' THEN date_format(from_utc_timestamp(a.min_start_time, 'Africa/Abidjan'), 'EEEE')
        WHEN f.country_code_3d = 'JOR' THEN date_format(from_utc_timestamp(a.min_start_time, 'Asia/Amman'), 'EEEE')
        WHEN f.country_code_3d = 'KEN' THEN date_format(from_utc_timestamp(a.min_start_time, 'Africa/Nairobi'), 'EEEE')

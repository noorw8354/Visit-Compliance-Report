        WHEN f.country_code_3d = 'KWT' THEN date_format(from_utc_timestamp(a.min_start_time, 'Asia/Kuwait'), 'EEEE')
        WHEN f.country_code_3d = 'LBN' THEN date_format(from_utc_timestamp(a.min_start_time, 'Asia/Beirut'), 'EEEE')

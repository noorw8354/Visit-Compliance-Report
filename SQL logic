        WHEN f.country_code_3d = 'ARE' THEN from_utc_timestamp(b.Call_Datetime_vod__c, 'Asia/Dubai')
        ELSE b.Call_Datetime_vod__c
      END AS Call_Datetime_Local,

      /* Local Start Time (MIN(Start_Time_vod__c)) */
      CASE
        WHEN f.country_code_3d = 'DZA' THEN from_utc_timestamp(a.min_start_time, 'Africa/Algiers')
        WHEN f.country_code_3d = 'BHR' THEN from_utc_timestamp(a.min_start_time, 'Asia/Bahrain')
        WHEN f.country_code_3d = 'BEN' THEN from_utc_timestamp(a.min_start_time, 'Africa/Porto-Novo')
        WHEN f.country_code_3d = 'CMR' THEN from_utc_timestamp(a.min_start_time, 'Africa/Douala')
        WHEN f.country_code_3d = 'COG' THEN from_utc_timestamp(a.min_start_time, 'Africa/Brazzaville')
        WHEN f.country_code_3d = 'COD' THEN from_utc_timestamp(a.min_start_time, 'Africa/Kinshasa')
        WHEN f.country_code_3d = 'EGY' THEN from_utc_timestamp(a.min_start_time, 'Africa/Cairo')
        WHEN f.country_code_3d = 'GAB' THEN from_utc_timestamp(a.min_start_time, 'Africa/Libreville')
        WHEN f.country_code_3d = 'CIV' THEN from_utc_timestamp(a.min_start_time, 'Africa/Abidjan')
        WHEN f.country_code_3d = 'JOR' THEN from_utc_timestamp(a.min_start_time, 'Asia/Amman')
        WHEN f.country_code_3d = 'KEN' THEN from_utc_timestamp(a.min_start_time, 'Africa/Nairobi')
        WHEN f.country_code_3d = 'SAU' THEN from_utc_timestamp(a.min_start_time, 'Asia/Riyadh')
        WHEN f.country_code_3d = 'KWT' THEN from_utc_timestamp(a.min_start_time, 'Asia/Kuwait')
        WHEN f.country_code_3d = 'LBN' THEN from_utc_timestamp(a.min_start_time, 'Asia/Beirut')
        WHEN f.country_code_3d = 'MUS' THEN from_utc_timestamp(a.min_start_time, 'Indian/Mauritius')
        WHEN f.country_code_3d = 'MAR' THEN from_utc_timestamp(a.min_start_time, 'Africa/Casablanca')
        WHEN f.country_code_3d = 'NGA' THEN from_utc_timestamp(a.min_start_time, 'Africa/Lagos')
        WHEN f.country_code_3d = 'OMN' THEN from_utc_timestamp(a.min_start_time, 'Asia/Muscat')
        WHEN f.country_code_3d = 'PAK' THEN from_utc_timestamp(a.min_start_time, 'Asia/Karachi')
        WHEN f.country_code_3d = 'QAT' THEN from_utc_timestamp(a.min_start_time, 'Asia/Qatar')
        WHEN f.country_code_3d = 'ZAF' THEN from_utc_timestamp(a.min_start_time, 'Africa/Johannesburg')
        WHEN f.country_code_3d = 'SEN' THEN from_utc_timestamp(a.min_start_time, 'Africa/Dakar')
        WHEN f.country_code_3d = 'TGO' THEN from_utc_timestamp(a.min_start_time, 'Africa/Lome')
        WHEN f.country_code_3d = 'TUR' THEN from_utc_timestamp(a.min_start_time, 'Europe/Istanbul')
        WHEN f.country_code_3d = 'ARE' THEN from_utc_timestamp(a.min_start_time, 'Asia/Dubai')
        ELSE a.min_start_time
      END AS start_time,

      /* Time-only format (hh:mm a) based on MIN(Start_Time_vod__c) */
      CASE
        WHEN f.country_code_3d = 'DZA' THEN date_format(from_utc_timestamp(a.min_start_time, 'Africa/Algiers'), 'hh:mm a')
        WHEN f.country_code_3d = 'BHR' THEN date_format(from_utc_timestamp(a.min_start_time, 'Asia/Bahrain'), 'hh:mm a')
        WHEN f.country_code_3d = 'BEN' THEN date_format(from_utc_timestamp(a.min_start_time, 'Africa/Porto-Novo'), 'hh:mm a')
        WHEN f.country_code_3d = 'CMR' THEN date_format(from_utc_timestamp(a.min_start_time, 'Africa/Douala'), 'hh:mm a')
        WHEN f.country_code_3d = 'COG' THEN date_format(from_utc_timestamp(a.min_start_time, 'Africa/Brazzaville'), 'hh:mm a')
        WHEN f.country_code_3d = 'COD' THEN date_format(from_utc_timestamp(a.min_start_time, 'Africa/Kinshasa'), 'hh:mm a')
        WHEN f.country_code_3d = 'EGY' THEN date_format(from_utc_timestamp(a.min_start_time, 'Africa/Cairo'), 'hh:mm a')
        WHEN f.country_code_3d = 'GAB' THEN date_format(from_utc_timestamp(a.min_start_time, 'Africa/Libreville'), 'hh:mm a')
        WHEN f.country_code_3d = 'CIV' THEN date_format(from_utc_timestamp(a.min_start_time, 'Africa/Abidjan'), 'hh:mm a')
        WHEN f.country_code_3d = 'JOR' THEN date_format(from_utc_timestamp(a.min_start_time, 'Asia/Amman'), 'hh:mm a')
        WHEN f.country_code_3d = 'KEN' THEN date_format(from_utc_timestamp(a.min_start_time, 'Africa/Nairobi'), 'hh:mm a')
        WHEN f.country_code_3d = 'SAU' THEN date_format(from_utc_timestamp(a.min_start_time, 'Asia/Riyadh'), 'hh:mm a')
        WHEN f.country_code_3d = 'KWT' THEN date_format(from_utc_timestamp(a.min_start_time, 'Asia/Kuwait'), 'hh:mm a')
        WHEN f.country_code_3d = 'LBN' THEN date_format(from_utc_timestamp(a.min_start_time, 'Asia/Beirut'), 'hh:mm a')
        WHEN f.country_code_3d = 'MUS' THEN date_format(from_utc_timestamp(a.min_start_time, 'Indian/Mauritius'), 'hh:mm a')

        WHEN f.country_code_3d = 'SEN' THEN from_utc_timestamp(b.Call_Datetime_vod__c, 'Africa/Dakar')
        WHEN f.country_code_3d = 'TGO' THEN from_utc_timestamp(b.Call_Datetime_vod__c, 'Africa/Lome')

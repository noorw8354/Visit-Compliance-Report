SELECT
  g.call_id,
  g.Check_In_Status_vod__c,
  g.Check_In_Timestamp_vod__c,
  g.call_date_calls,
  g.min_start_time,
  g.max_start_time,
  g.Check_In_Latitude_vod__c,
  g.Check_In_Longitude_vod__c,
  g.CLM_Location_Latitude_vod__c,
  g.CLM_Location_Longitude_vod__c,
  g.checkin_clm_distance_m,
  g.add_lon,
  g.add_lat,
  g.location_validity,
  g.Address_vod__c,
  g.Call_Datetime_Local,
  g.start_time,
  g.call_time_format,
  g.week_day,
  g.call_validity,
  g.Time_Diff_days,
  g.status,
  g.OwnerId,
  g.territory_id,
  g.user_name,
  g.account_name,
  g.manager_name,
  g.Market,
  g.country_code_3d,
  g.call_status,
  g.Final_Validity_Check,
  /* -------- next-call time difference (minutes) per user & country -------- */
  g.call_diff_min,
  g.line
 

FROM
(
  SELECT
    bc.*,


    /* Distance between Check-In and CLM in meters */
CASE
  WHEN Check_In_Latitude_vod__c IS NULL
    OR Check_In_Longitude_vod__c IS NULL
    OR CLM_Location_Latitude_vod__c IS NULL
    OR CLM_Location_Longitude_vod__c IS NULL
  THEN NULL
  ELSE
    6371000.0 * 2 * asin(
      sqrt(
        pow(
          sin(
            (radians(CLM_Location_Latitude_vod__c)
             - radians(Check_In_Latitude_vod__c)) / 2
          ),
          2
        )
        +
        cos(radians(Check_In_Latitude_vod__c))
        * cos(radians(CLM_Location_Latitude_vod__c))
        * pow(
            sin(
              (radians(CLM_Location_Longitude_vod__c)
               - radians(Check_In_Longitude_vod__c)) / 2
            ),
            2
          )
      )
    )
END AS checkin_clm_distance_m,

    /* ---------- Haversine distances (meters) ---------- */
    6371000.0 * 2 * asin(
      sqrt(
        pow(sin((radians(CLM_Location_Latitude_vod__c) - radians(Check_In_Latitude_vod__c)) / 2), 2) +
        cos(radians(Check_In_Latitude_vod__c)) *
        cos(radians(CLM_Location_Latitude_vod__c)) *
        pow(sin((radians(CLM_Location_Longitude_vod__c) - radians(Check_In_Longitude_vod__c)) / 2), 2)
      )
    ) AS dist12,

    6371000.0 * 2 * asin(
      sqrt(
        pow(sin((radians(add_lat) - radians(Check_In_Latitude_vod__c)) / 2), 2) +
        cos(radians(Check_In_Latitude_vod__c)) *
        cos(radians(add_lat)) *
        pow(sin((radians(add_lon) - radians(Check_In_Longitude_vod__c)) / 2), 2)
      )
    ) AS dist13,

    6371000.0 * 2 * asin(
      sqrt(
        pow(sin((radians(add_lat) - radians(CLM_Location_Latitude_vod__c)) / 2), 2) +
        cos(radians(CLM_Location_Latitude_vod__c)) *
        cos(radians(add_lat)) *
        pow(sin((radians(add_lon) - radians(CLM_Location_Longitude_vod__c)) / 2), 2)
      )
    ) AS dist23,

    /* ---------- Location validity ---------- */
    CASE
      when CLM_Location_Latitude_vod__c is null OR CLM_Location_Longitude_vod__c is null OR Check_In_Latitude_vod__c is Null or Check_In_Longitude_vod__c is Null then 'Blank'
      WHEN (6371000.0 * 2 * asin(
              sqrt(
                pow(sin((radians(CLM_Location_Latitude_vod__c) - radians(Check_In_Latitude_vod__c)) / 2), 2) +
                cos(radians(Check_In_Latitude_vod__c)) *
                cos(radians(CLM_Location_Latitude_vod__c)) *
                pow(sin((radians(CLM_Location_Longitude_vod__c) - radians(Check_In_Longitude_vod__c)) / 2), 2)
              )
           )) > 100
        OR (6371000.0 * 2 * asin(
              sqrt(
                pow(sin((radians(add_lat) - radians(Check_In_Latitude_vod__c)) / 2), 2) +
                cos(radians(Check_In_Latitude_vod__c)) *
                cos(radians(add_lat)) *
                pow(sin((radians(add_lon) - radians(Check_In_Longitude_vod__c)) / 2), 2)
              )
           )) > 100
        OR (6371000.0 * 2 * asin(
              sqrt(
                pow(sin((radians(add_lat) - radians(CLM_Location_Latitude_vod__c)) / 2), 2) +
                cos(radians(CLM_Location_Latitude_vod__c)) *
                cos(radians(add_lat)) *
                pow(sin((radians(add_lon) - radians(CLM_Location_Longitude_vod__c)) / 2), 2)
              )
           )) > 100
      THEN 'Invalid'
      ELSE 'Valid'
    END AS location_validity,

    /* ---------- Final validity ---------- */
    CASE
      WHEN (
        CASE
          WHEN (6371000.0 * 2 * asin(
                  sqrt(
                    pow(sin((radians(CLM_Location_Latitude_vod__c) - radians(Check_In_Latitude_vod__c)) / 2), 2) +
                    cos(radians(Check_In_Latitude_vod__c)) *
                    cos(radians(CLM_Location_Latitude_vod__c)) *
                    pow(sin((radians(CLM_Location_Longitude_vod__c) - radians(Check_In_Longitude_vod__c)) / 2), 2)
                  )
               )) > 100
            OR (6371000.0 * 2 * asin(
                  sqrt(
                    pow(sin((radians(add_lat) - radians(Check_In_Latitude_vod__c)) / 2), 2) +
                    cos(radians(Check_In_Latitude_vod__c)) *
                    cos(radians(add_lat)) *
                    pow(sin((radians(add_lon) - radians(Check_In_Longitude_vod__c)) / 2), 2)
                  )
               )) > 100
            OR (6371000.0 * 2 * asin(
                  sqrt(
                    pow(sin((radians(add_lat) - radians(CLM_Location_Latitude_vod__c)) / 2), 2) +
                    cos(radians(CLM_Location_Latitude_vod__c)) *
                    cos(radians(add_lat)) *
                    pow(sin((radians(add_lon) - radians(CLM_Location_Longitude_vod__c)) / 2), 2)
                  )
               )) > 100
          THEN 'Invalid' 
          when CLM_Location_Latitude_vod__c is null OR CLM_Location_Longitude_vod__c is null OR Check_In_Latitude_vod__c is Null or Check_In_Longitude_vod__c is Null then 'Blank'
          ELSE 'Valid'
        END
      ) = 'Valid'
      AND call_validity = 'Valid Call'
      THEN 'Valid Call'
      ELSE 'Invalid Call'
    END AS Final_Validity_Check

  FROM
  (
    /* ---------- Base calls + timezones + rules ---------- */
    SELECT
      b.id AS call_id,
      b.Check_In_Status_vod__c,
      b.Check_In_Timestamp_vod__c,
